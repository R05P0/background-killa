#!/sbin/sh
# Background Killa - Magisk Module Installer

SKIPUNZIP=1

if [ -f /data/adb/magisk/util_functions.sh ]; then
    . /data/adb/magisk/util_functions.sh
else
    ui_print "ERROR: Magisk not found. Please install Magisk v20.4+ first."
    exit 1
fi

ui_print ""
ui_print "╔══════════════════════════════╗"
ui_print "║      BACKGROUND KILLA        ║"
ui_print "║   Force-Kill FG Exited Apps  ║"
ui_print "╚══════════════════════════════╝"
ui_print ""

ui_print "- Extracting module files..."
# Extract everything except META-INF to preserve cgi-bin subdir
unzip -o "$ZIPFILE" -d "$MODPATH" -x 'META-INF/*' 'build.sh' >&2

ui_print "- Setting permissions..."
set_perm "$MODPATH/service.sh"             root root 0755
set_perm "$MODPATH/monitor.sh"             root root 0755
set_perm "$MODPATH/action.sh"              root root 0755
set_perm "$MODPATH/uninstall.sh"           root root 0755
set_perm "$MODPATH/webroot/cgi-bin/api.sh" root root 0755

mkdir -p "$MODPATH/config"
touch "$MODPATH/config/kill_list.txt"
chmod 644 "$MODPATH/config/kill_list.txt"

ui_print ""
ui_print "- Installation complete!"
ui_print "- Tap the Action button in Magisk to open WebUI"
ui_print "- Or: adb forward tcp:8765 tcp:8765 → http://localhost:8765"
ui_print ""

exit 0
